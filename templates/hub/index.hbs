<section class="hub-index">
  <div class="doctype-filter">
    {{#each doctypeFilter.chips}}
    <span class="doctype-chip" data-type="{{this.type}}">
      <i class="{{this.icon}}"></i> {{this.label}}
      <a data-action="removeType" data-type="{{this.type}}"
         data-tooltip="CAMPAIGNRECORD.Hub.RemoveType"
         aria-label="{{localize "CAMPAIGNRECORD.Hub.RemoveType"}}"><i class="fa-solid fa-xmark"></i></a>
    </span>
    {{/each}}
    <select class="doctype-add" aria-label="{{localize "CAMPAIGNRECORD.Hub.TypeFilter"}}">
      <option value="">{{localize "CAMPAIGNRECORD.Hub.AddType"}}</option>
      {{#each doctypeFilter.available}}
      <option value="{{this.type}}">{{this.label}}</option>
      {{/each}}
    </select>
    {{#if doctypeFilter.hasSelection}}
    <button type="button" class="doctype-clear" data-action="clearTypes"
            data-tooltip="CAMPAIGNRECORD.Hub.ClearTypes"
            aria-label="{{localize "CAMPAIGNRECORD.Hub.ClearTypes"}}">
      <i class="fa-solid fa-xmark"></i>
    </button>
    {{/if}}
  </div>
  <div class="index-controls">
    <button type="button" class="rail-toggle" data-action="toggleRail"
            data-tooltip="CAMPAIGNRECORD.Hub.ToggleRail"
            aria-label="{{localize "CAMPAIGNRECORD.Hub.ToggleRail"}}">
      <i class="fa-solid fa-angles-left"></i>
    </button>
    <input type="search" name="index-search" value="{{state.query}}"
           placeholder="{{localize "CAMPAIGNRECORD.Hub.FilterTag"}}" autocomplete="off">
    <label class="snippets-toggle">
      <input type="checkbox" name="snippets-toggle" data-action="toggleSnippets"
             {{#if snippets}}checked{{/if}}>
      {{localize "CAMPAIGNRECORD.Hub.Snippets"}}
    </label>
    <select name="sort-select">
      {{#each sortOptions}}
      <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
      {{/each}}
    </select>
    {{#if isGM}}
    <button type="button" class="hidden-toggle {{#if state.hiddenOnly}}active{{/if}}"
            data-action="toggleHiddenOnly" data-tooltip="CAMPAIGNRECORD.Hub.HiddenOnly">
      <i class="fa-solid fa-eye-slash"></i>
    </button>
    {{/if}}
    {{#if hasActiveFilters}}
    <span class="filtered-count">{{localize "CAMPAIGNRECORD.Hub.FilteredCount" shown=filteredCount total=totalCount}}</span>
    {{/if}}
  </div>
  {{#if otherGroupMatches}}
  <button type="button" class="other-group-matches" data-action="clearFilters">
    {{localize "CAMPAIGNRECORD.Hub.OtherGroupMatches" count=otherGroupMatches}}
  </button>
  {{/if}}
  <ol class="record-list">
    {{#if grouped}}
      {{#each recordGroups}}
      <li class="record-group-header">{{this.label}}</li>
      {{#each this.records}}{{> campaign-record.hub-index-row}}{{/each}}
      {{/each}}
    {{else}}
      {{#each records}}{{> campaign-record.hub-index-row}}{{/each}}
    {{/if}}
    {{#unless records.length}}
    <li class="hint">{{localize "CAMPAIGNRECORD.Hub.NoRecords"}}</li>
    {{/unless}}
  </ol>
</section>
